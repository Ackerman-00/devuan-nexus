#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_build:
	# Nothing to build — binary repackage only
	true

# Skip dwz: upstream Electron binaries have no/partial debug info
override_dh_dwz:

# Skip shlibdeps: upstream ships prebuilt Electron binaries with bundled libraries.
override_dh_shlibdeps:
	@echo "Skipping dh_shlibdeps for repackaged upstream binaries."

override_dh_auto_install:
	# Files were already extracted by the workflow into the current directory.
	# We just need to place them into the Debian packaging tree.

	# Install application files
	mkdir -p debian/vesktop/opt
	cp -a opt/Vesktop debian/vesktop/opt/

	# Install desktop entry and icons
	mkdir -p debian/vesktop/usr/share/applications
	mkdir -p debian/vesktop/usr/share/icons
	cp -a usr/share/applications/* debian/vesktop/usr/share/applications/ || true
	cp -a usr/share/icons/* debian/vesktop/usr/share/icons/ || true

	# Create executable symlink
	mkdir -p debian/vesktop/usr/bin
	ln -sf /opt/Vesktop/vesktop debian/vesktop/usr/bin/vesktop

override_dh_fixperms:
	# dh_fixperms strips SUID bits by default for security reasons.
	# We must exclude chrome-sandbox so it retains the 4755 SUID bit required by Electron.
	dh_fixperms -Xchrome-sandbox
	chmod 4755 debian/vesktop/opt/Vesktop/chrome-sandbox
