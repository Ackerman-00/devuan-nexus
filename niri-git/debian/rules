#!/usr/bin/make -f

export DH_VERBOSE = 1

# Enforce your custom x86-64-v3 flags natively for standard Debian builds
export RUSTFLAGS = -C target-cpu=x86-64-v3 -C opt-level=3

%:
	dh $@

override_dh_auto_build:
	cargo fetch
	# The upstream default features are exactly what we want for Debian: 
	# dbus, systemd, xdp-gnome-screencast
	cargo build --release

override_dh_auto_install:
	mkdir -p debian/niri-git/usr/bin/
	mkdir -p debian/niri-git/usr/share/wayland-sessions/
	mkdir -p debian/niri-git/usr/share/xdg-desktop-portal/
	mkdir -p debian/niri-git/usr/lib/systemd/user/

	# Install binaries safely
	cp -vf target/release/niri debian/niri-git/usr/bin/niri
	chmod 755 debian/niri-git/usr/bin/niri

	# The upstream niri-session script natively supports systemd and imports environment
	cp -vf resources/niri-session debian/niri-git/usr/bin/niri-session
	chmod 755 debian/niri-git/usr/bin/niri-session

	# Install application rules and assets
	cp -vf resources/niri.desktop debian/niri-git/usr/share/wayland-sessions/niri.desktop
	cp -vf resources/niri-portals.conf debian/niri-git/usr/share/xdg-desktop-portal/niri-portals.conf

	# Native systemd user units provided by upstream repo
	cp -vf resources/niri.service debian/niri-git/usr/lib/systemd/user/niri.service
	cp -vf resources/niri-shutdown.target debian/niri-git/usr/lib/systemd/user/niri-shutdown.target
