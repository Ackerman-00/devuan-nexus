#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_build:
	# Nothing to build — tarball repackage only
	true

override_dh_auto_install:
	# The workflow extracts the tarball into the build root.
	# Zed's tarball contains the 'zed' CLI and the main editor binary/resources.
	
	mkdir -p debian/zed-editor/usr/lib/zed
	mkdir -p debian/zed-editor/usr/bin
	mkdir -p debian/zed-editor/usr/share/applications
	mkdir -p debian/zed-editor/usr/share/icons/hicolor/512x512/apps

	# Move all upstream files into /usr/lib/zed (excluding the injected 'debian' folder)
	rsync -a --exclude='debian' ./ debian/zed-editor/usr/lib/zed/
	
	# Symlink the CLI to /usr/bin/zeditor (as per official packager notes to avoid conflicts)
	ln -sf /usr/lib/zed/zed debian/zed-editor/usr/bin/zeditor
	
	# Generate the .desktop file using envsubst (as per official Zed packager docs)
	export APP_ID="dev.zed.Zed"
	export APP_NAME="Zed"
	export APP_CLI="zeditor"
	export APP_ICON="zed"
	export APP_ARGS="%U"
	export DO_STARTUP_NOTIFY="true"
	
	# The tarball includes the desktop template in resources/
	if [ -f debian/zed-editor/usr/lib/zed/resources/zed.desktop.in ]; then \
		envsubst < debian/zed-editor/usr/lib/zed/resources/zed.desktop.in > debian/zed-editor/usr/share/applications/dev.zed.Zed.desktop; \
	fi
	chmod 644 debian/zed-editor/usr/share/applications/dev.zed.Zed.desktop || true
	
	# Install icon from upstream resources
	if [ -f debian/zed-editor/usr/lib/zed/resources/app-icon.png ]; then \
		install -m0644 debian/zed-editor/usr/lib/zed/resources/app-icon.png debian/zed-editor/usr/share/icons/hicolor/512x512/apps/zed.png; \
	fi

override_dh_dwz:
	# Skip dwz for pre-compiled Rust binaries
	true

override_dh_strip:
	# Do not strip the upstream binaries
	dh_strip --no-automatic-dbgsym
