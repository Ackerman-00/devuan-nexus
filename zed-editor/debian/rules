#!/usr/bin/make -f

# x86-64-v3 + O3 optimizations
export DEB_CFLAGS_MAINT_APPEND = -march=x86-64-v3 -O3
export DEB_CXXFLAGS_MAINT_APPEND = -march=x86-64-v3 -O3
export RUSTFLAGS = -C target-cpu=x86-64-v3 -C opt-level=3 -C link-arg=-fuse-ld=mold

# Zed specific env vars (from Void template)
export CARGO_PROFILE_RELEASE_DEBUG = 0
export CARGO_PROFILE_RELEASE_STRIP = symbols
export ZED_UPDATE_EXPLANATION = Updates are handled by Devuan Nexus
export RELEASE_CHANNEL = stable

%:
	dh $@ --buildsystem=cargo

override_dh_auto_build:
	# Tell Zed this is a stable build
	printf "stable" > crates/zed/RELEASE_CHANNEL
	
	# Build exactly like Void (unsetting LIBGIT2_NO_VENDOR)
	env -u LIBGIT2_NO_VENDOR cargo build --release --path crates/zed

override_dh_auto_install:
	# Install binary
	install -Dm755 target/release/zed $(DESTDIR)/usr/bin/zed
	
	# Install icon
	install -Dm644 crates/zed/resources/app-icon.png $(DESTDIR)/usr/share/pixmaps/zed.png
	
	# Install desktop file
	install -d $(DESTDIR)/usr/share/applications
	cat > $(DESTDIR)/usr/share/applications/zed.desktop <<EOF
	[Desktop Entry]
	Version=1.0
	Type=Application
	Name=Zed
	GenericName=Text Editor
	Comment=A high-performance, multiplayer code editor.
	Exec=zed %U
	Icon=zed
	Terminal=false
	StartupNotify=true
	StartupWMClass=dev.zed.Zed
	Categories=Development;Utility;TextEditor;
	EOF

override_dh_dwz:
	# Skip dwz for Rust binaries
	true

override_dh_strip:
	# We already stripped symbols via cargo env var, skip debian strip
	dh_strip --no-automatic-dbgsym
