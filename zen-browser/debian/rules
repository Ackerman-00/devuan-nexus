#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_build:
	# Nothing to build — tarball repackage only
	true

# Skip dwz: upstream Firefox binaries have no/partial debug info
override_dh_dwz:

# Skip shlibdeps: upstream ships prebuilt Firefox-based binaries.
# All necessary runtime dependencies are declared in debian/control.
override_dh_shlibdeps:
	@echo "Skipping dh_shlibdeps for repackaged upstream binaries."

override_dh_auto_install:
	# Files were already extracted by the workflow into the current directory.
	# We use rsync to copy everything except the injected debian folder.

	# Install application files to /opt
	mkdir -p debian/zen-browser/opt/zen-browser
	rsync -a --exclude='debian' ./ debian/zen-browser/opt/zen-browser/

	# Create executable symlink
	mkdir -p debian/zen-browser/usr/bin
	ln -sf /opt/zen-browser/zen debian/zen-browser/usr/bin/zen

	# Install desktop entry
	mkdir -p debian/zen-browser/usr/share/applications
	cp -v ../zen-browser/debian/zen.desktop debian/zen-browser/usr/share/applications/zen.desktop

	# Install policies.json (disable auto-update)
	mkdir -p debian/zen-browser/opt/zen-browser/distribution
	cp -v ../zen-browser/debian/policies.json debian/zen-browser/opt/zen-browser/distribution/policies.json

	# Install icons
	for size in 16 32 48 64 128; do \
		if [ -f debian/zen-browser/opt/zen-browser/browser/chrome/icons/default/default$${size}.png ]; then \
			mkdir -p debian/zen-browser/usr/share/icons/hicolor/$${size}x$${size}/apps; \
			cp -v debian/zen-browser/opt/zen-browser/browser/chrome/icons/default/default$${size}.png \
				debian/zen-browser/usr/share/icons/hicolor/$${size}x$${size}/apps/zen.png; \
		fi; \
	done
	mkdir -p debian/zen-browser/usr/share/pixmaps
	if [ -f debian/zen-browser/opt/zen-browser/browser/chrome/icons/default/default48.png ]; then \
		cp -v debian/zen-browser/opt/zen-browser/browser/chrome/icons/default/default48.png \
			debian/zen-browser/usr/share/pixmaps/zen.png; \
	fi

	# Replace bundled NSS/NSPR with symlinks to system libraries
	for lib in libnspr4.so libnss3.so libnssutil3.so libplc4.so \
	           libplds4.so libsmime3.so libssl3.so libnssckbi.so; do \
		if [ -f "debian/zen-browser/opt/zen-browser/$$lib" ]; then \
			rm -f "debian/zen-browser/opt/zen-browser/$$lib"; \
			ln -sf /usr/lib/x86_64-linux-gnu/$$lib "debian/zen-browser/opt/zen-browser/$$lib"; \
		fi; \
	done

	# Link system dictionaries for spellcheck
	ln -sf /usr/share/hunspell debian/zen-browser/opt/zen-browser/dictionaries
	ln -sf /usr/share/hyphen debian/zen-browser/opt/zen-browser/hyphenation
