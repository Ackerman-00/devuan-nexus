#!/usr/bin/make -f

export DH_VERBOSE = 1
export CXXFLAGS = -O3 -march=x86-64-v3 -mtune=generic
export CFLAGS = -O3 -march=x86-64-v3 -mtune=generic

%:
	dh $@

override_dh_auto_configure:
	# Patch: upstream uses -march=native which breaks reproducible builds
	sed -i "s/-march=native/-march=x86-64-v3/g" meson.build
	sed -i "s/-mtune=native/-mtune=generic/g" meson.build
	meson setup build --buildtype=release --prefix=/usr -Db_ndebug=true
	dh_auto_configure --buildsystem=meson --builddirectory=build

override_dh_auto_build:
	dh_auto_build --buildsystem=meson --builddirectory=build

override_dh_auto_install:
	dh_auto_install --buildsystem=meson --builddirectory=build
	# Remove any systemd user service files (none in v5 currently)
	rm -rf debian/noctalia-v5-git/usr/lib/systemd || true
